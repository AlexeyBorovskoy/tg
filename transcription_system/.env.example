APP_HOST=127.0.0.1
APP_PORT=8081
APP_DEBUG=0

# Provider: assemblyai | local_whisper | compare | mock
TRANSCRIPTION_PROVIDER=mock
ASSEMBLYAI_API_KEY=
ASSEMBLYAI_SPEECH_MODELS=universal-2
WHISPER_MODEL_SIZE=large-v3
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=int8
WHISPER_BEAM_SIZE=5
WHISPER_CPU_THREADS=4
WHISPER_VAD_FILTER=1

TRANSCRIBE_POLL_INTERVAL=3
TRANSCRIBE_UPLOAD_TIMEOUT=300
TRANSCRIBE_REQUEST_TIMEOUT=60

# Optional postprocessing (reserved for next step)
OPENAI_API_KEY=
# Совместимо с TG Digest: поддерживаются OPENAI_BASE_URL и OPENAI_API_BASE
OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_MODEL_CANDIDATES=gpt-5,gpt-4.1,gpt-4o,gpt-4o-mini
# Совместимо с TG Digest: если задан OPENAI_MAX_TOKENS, он будет использован как fallback
# OPENAI_MAX_TOKENS=2500
LLM_ENABLED_DEFAULT=1
LLM_TIMEOUT_SEC=60
LLM_MAX_INPUT_CHARS=18000
LLM_MAX_OUTPUT_TOKENS=2500

# Local auth (same approach as TG Digest)
AUTH_LOCAL_ENABLED=1
AUTH_SESSION_DAYS=14
ADMIN_LOGIN=Alex
ADMIN_PASSWORD=change_me_strong_password

# Shared auth with TG Digest (single sign-on via user_sessions/session_token)
AUTH_SHARED_ENABLED=0
AUTH_SHARED_COOKIE_NAME=session_token
AUTH_SHARED_LOGIN_URL=http://localhost:8010/login
AUTH_SHARED_REGISTER_URL=http://localhost:8010/register
AUTH_SHARED_ADMIN_LOGIN=Alex
# Shared PostgreSQL (TG Digest DB)
# PGHOST=127.0.0.1
# PGPORT=5432
# PGDATABASE=tg_digest
# PGUSER=tg_digest
# PGPASSWORD=change_me

# Audio retention policy (0 = delete source audio after processing)
KEEP_UPLOADED_AUDIO=0

# URL shown on /resources for TG Digest
RESOURCE_TG_DIGEST_URL=http://localhost:8010/setup
